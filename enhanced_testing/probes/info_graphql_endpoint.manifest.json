{
  "author": "Tim Rice <tim.j.rice@hackrange.com>",
  "name": "info_graphql_endpoint",
  "version": "1.0",
  "summary": "Re-runs the GraphQL introspection probe against common /graphql paths.",
  "validates": [
    "CWE-200"
  ],
  "matches_titles": [
    "info_graphql_endpoint",
    "graphql introspection"
  ],
  "matches_tools": [
    "enhanced_testing",
    "nuclei"
  ],
  "safety_class": "read-only",
  "requires_post": true,
  "request_budget_typical": 5,
  "request_budget_max": 10,
  "args": {
    "--url": "Target origin URL",
    "--path": "Additional GraphQL path (repeatable)"
  }
}
