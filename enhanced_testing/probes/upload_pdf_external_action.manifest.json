{
  "author": "Tim Rice <tim.j.rice@hackrange.com>",
  "name": "upload_pdf_external_action",
  "version": "1.0",
  "summary": "Detects upload handlers that accept PDFs with /OpenAction /URI triggers and serve them unmodified.",
  "validates": [
    "CWE-918",
    "CWE-829"
  ],
  "matches_titles": [
    "upload_pdf_external_action",
    "pdf openaction upload",
    "pdf uri action"
  ],
  "matches_tools": [
    "enhanced_testing"
  ],
  "safety_class": "probe",
  "requires_post": true,
  "request_budget_typical": 2,
  "request_budget_max": 4,
  "args": {
    "--url": "Target origin URL",
    "--upload-path": "Additional upload endpoint to try (repeatable)",
    "--field": "Multipart field name (default: file)"
  }
}
