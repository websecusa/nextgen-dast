{
  "author": "Tim Rice <tim.j.rice@hackrange.com>",
  "name": "redos_any_string_field",
  "version": "1.0",
  "summary": "Re-runs the ReDoS probe across common string-field endpoints and asserts whether a catastrophic-backtracking payload still produces a >2s response delta.",
  "validates": [
    "CWE-1333",
    "CWE-407",
    "CWE-400"
  ],
  "matches_titles": [
    "redos_any_string_field",
    "regular expression denial of service",
    "redos",
    "catastrophic backtracking"
  ],
  "matches_tools": [
    "enhanced_testing"
  ],
  "safety_class": "read-only",
  "requires_post": true,
  "request_budget_typical": 30,
  "request_budget_max": 80,
  "args": {
    "--url": "Site origin to probe",
    "--threshold-ms": "Minimum benign-vs-catastrophic delta in ms (default 2000)"
  }
}
