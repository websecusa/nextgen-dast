{
  "author": "Tim Rice <tim.j.rice@hackrange.com>",
  "name": "clientjs_localstorage_sensitive",
  "version": "1.0",
  "summary": "Detects localStorage / sessionStorage setItem calls writing token-shaped keys with non-literal values.",
  "validates": [
    "CWE-922",
    "CWE-312"
  ],
  "matches_titles": [
    "clientjs_localstorage_sensitive",
    "localStorage",
    "sessionStorage",
    "client storage token"
  ],
  "matches_tools": [
    "enhanced_testing"
  ],
  "safety_class": "read-only",
  "requires_post": false,
  "request_budget_typical": 4,
  "request_budget_max": 6,
  "args": {
    "--url": "Target origin URL",
    "--bundle": "Additional bundle URL/path to scan (repeatable)"
  }
}
