{
  "author": "Tim Rice <tim.j.rice@hackrange.com>",
  "name": "auth_session_fixation_no_rotation",
  "version": "1.0",
  "summary": "Re-runs the session-fixation probe and asserts whether the session id is still byte-identical before and after a login.",
  "validates": [
    "CWE-384",
    "CWE-613",
    "CWE-287"
  ],
  "matches_titles": [
    "auth_session_fixation_no_rotation",
    "session fixation",
    "session id not rotated",
    "no session rotation",
    "session not regenerated on login"
  ],
  "matches_tools": [
    "enhanced_testing"
  ],
  "safety_class": "read-only",
  "requires_post": true,
  "request_budget_typical": 8,
  "request_budget_max": 16,
  "args": {
    "--url": "Site origin to probe",
    "--login-path": "Additional login endpoint (repeatable)"
  }
}
