{
  "author": "Tim Rice <tim.j.rice@hackrange.com>",
  "name": "xss_stored_via_request_headers",
  "version": "1.0",
  "summary": "Re-runs the request-header stored-XSS probe and asserts whether the marker still appears un-escaped on any reflective surface.",
  "validates": [
    "CWE-79",
    "CWE-80"
  ],
  "matches_titles": [
    "xss_stored_via_request_headers",
    "stored xss header",
    "request header xss",
    "header injection xss",
    "stored xss"
  ],
  "matches_tools": [
    "enhanced_testing"
  ],
  "safety_class": "read-only",
  "requires_post": true,
  "request_budget_typical": 80,
  "request_budget_max": 200,
  "args": {
    "--url": "Site origin to probe",
    "--header": "Additional injection header to try (repeatable)"
  }
}
