{
  "author": "Tim Rice <tim.j.rice@hackrange.com>",
  "name": "authz_websocket_unauthenticated",
  "version": "1.0",
  "summary": "Detects WebSocket endpoints that complete the handshake for an unauthenticated caller.",
  "validates": [
    "CWE-306"
  ],
  "matches_titles": [
    "authz_websocket_unauthenticated",
    "websocket authorization",
    "ws anonymous"
  ],
  "matches_tools": [
    "enhanced_testing"
  ],
  "safety_class": "read-only",
  "requires_post": false,
  "request_budget_typical": 4,
  "request_budget_max": 6,
  "args": {
    "--url": "Target origin URL",
    "--ws-path": "Additional WebSocket path to probe (repeatable)"
  }
}
