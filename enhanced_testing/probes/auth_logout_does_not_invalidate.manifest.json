  ],
  "matches_tools": [
    "enhanced_testing"
  ],
  "safety_class": "read-only",
  "requires_post": true,
  "request_budget_typical": 5,
  "request_budget_max": 12,
  "args": {
    "--url": "Target origin URL",
    "--logout-path": "Additional logout path (repeatable)"
  }
}
