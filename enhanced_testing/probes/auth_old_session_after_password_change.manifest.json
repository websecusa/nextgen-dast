{
  "author": "Tim Rice <tim.j.rice@hackrange.com>",
  "name": "auth_old_session_after_password_change",
  "version": "1.0",
  "summary": "Detects pre-password-change sessions that remain authenticated after the password is rotated.",
  "validates": [
    "CWE-613"
  ],
  "matches_titles": [
    "auth_old_session_after_password_change",
    "session not invalidated",
    "concurrent session"
  ],
  "matches_tools": [
    "enhanced_testing"
  ],
  "safety_class": "probe",
  "requires_post": true,
  "request_budget_typical": 6,
  "request_budget_max": 10,
  "args": {
    "--url": "Target origin URL",
    "--change-path": "Additional change-password endpoint to try (repeatable)"
  }
}
