{
  "author": "Tim Rice <tim.j.rice@hackrange.com>",
  "name": "auth_oauth_password_from_email",
  "version": "1.0",
  "summary": "Re-runs the OAuth-password-from-email probe: posts base64(email) as the password and checks whether the server issues a valid session.",
  "validates": [
    "CWE-521",
    "CWE-287",
    "CWE-330"
  ],
  "matches_titles": [
    "auth_oauth_password_from_email",
    "weak password derivation",
    "predictable password",
    "oauth fallback"
  ],
  "matches_tools": [
    "enhanced_testing"
  ],
  "safety_class": "read-only",
  "requires_post": true,
  "request_budget_typical": 4,
  "request_budget_max": 12,
  "args": {
    "--url": "Target origin URL",
    "--email": "Additional OAuth email to test (repeatable)"
  }
}
