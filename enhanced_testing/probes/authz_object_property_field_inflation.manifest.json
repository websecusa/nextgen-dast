{
  "author": "Tim Rice <tim.j.rice@hackrange.com>",
  "name": "authz_object_property_field_inflation",
  "version": "1.0",
  "summary": "Detects broken object-property-level authorization: `?fields=` selector returns hidden user columns like password_hash and ssn.",
  "validates": [
    "CWE-213",
    "CWE-285"
  ],
  "matches_titles": [
    "authz_object_property_field_inflation",
    "broken object property level authorization",
    "BOPLA",
    "fields parameter inflation"
  ],
  "matches_tools": [
    "enhanced_testing"
  ],
  "safety_class": "probe",
  "requires_post": true,
  "request_budget_typical": 4,
  "request_budget_max": 8,
  "args": {
    "--url": "Target origin URL",
    "--me-path": "Additional self-profile endpoint to probe (repeatable)"
  }
}