# Author: Tim Rice <tim.j.rice@hackrange.com>
# Part of nextgen-dast. See README.md for license and overall architecture.
# Pentest-proxy environment file.
#
# `setup.sh bootstrap` will generate a secured copy of this file with random
# secrets at .env_<random-hex>. Edit the resulting file (chmod 600) — never
# commit it.
#
# If you prefer to author it by hand, copy this file to `.env` and fill in
# every value. Generate strong secrets with:
#     openssl rand -hex 24
#     openssl rand -hex 32   # for APP_SECRET (longer)

# Random hex tag that's appended to the on-disk secrets file name. Lets the
# secrets file live at /data/.sensitive_secrets_info_<suffix> so naive
# scrapers grep'ing for ".sensitive_secrets_info" don't find it.
ENV_SUFFIX=changeme

# MariaDB credentials. The pentest user is what the app connects as; the
# root password is only used for administration / mariadb-cli access.
MARIADB_ROOT_PASSWORD=changeme-root
MARIADB_DATABASE=pentest
MARIADB_USER=pentest
MARIADB_PASSWORD=changeme-app

# Where the on-host secrets file lives inside the container's /data mount.
# After bootstrap, the admin password is written here. Keep it chmod 600.
SECRETS_FILE=/data/.sensitive_secrets_info

# Public URL for the web UI — used by the auth flow for redirects after
# login. Must end with a trailing slash. Examples:
#   https://pentest.example.com/test/
#   https://10.0.0.5/test/
APP_URL=https://localhost/test/

# Symmetric key used to sign session cookies. Anything 32+ random bytes.
# Rotating this invalidates every existing session.
APP_SECRET=changeme-32-random-bytes-here
